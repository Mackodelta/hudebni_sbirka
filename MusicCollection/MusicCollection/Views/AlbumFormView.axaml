<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicCollection.ViewModels"
             x:Class="MusicCollection.Views.AlbumFormView"
             x:DataType="vm:AlbumFormViewModel">

  <Border Background="#0f0f1e" Padding="0">
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Hlavička -->
      <Border Grid.Row="0" Background="#1a1a2e" Padding="24,16">
        <TextBlock Text="{Binding Titulek}" FontSize="20" FontWeight="Bold"
                   Foreground="White"/>
      </Border>

      <!-- Formulář -->
      <ScrollViewer Grid.Row="1" Padding="24">
        <StackPanel Spacing="16" MaxWidth="480">

          <StackPanel Spacing="4">
            <TextBlock Text="Název alba *" Classes="label"/>
            <TextBox Text="{Binding Nazev}" Watermark="Název alba"/>
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="Interpret *" Classes="label"/>
            <TextBox Text="{Binding Interpret}" Watermark="Jméno interpreta nebo kapely"/>
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="Rok vydání *" Classes="label"/>
            <TextBox Text="{Binding Rok}" Watermark="např. 2024"/>
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="Žánr *" Classes="label"/>
            <ComboBox ItemsSource="{Binding Zanry}"
                      SelectedItem="{Binding VybranyZanr}"
                      DisplayMemberBinding="{Binding Nazev}"
                      HorizontalAlignment="Stretch"/>
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="Popis (volitelný)" Classes="label"/>
            <TextBox Text="{Binding Popis}"
                     Watermark="Poznámky k albu..."
                     AcceptsReturn="True"
                     Height="80"
                     TextWrapping="Wrap"/>
          </StackPanel>

          <!-- Chyba validace -->
          <Border Background="#3a1a1a" CornerRadius="6" Padding="12,8"
                  IsVisible="{Binding Chyba, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="⚠️"/>
              <TextBlock Text="{Binding Chyba}" Foreground="#ff8888" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- Tlačítka -->
      <Border Grid.Row="2" Background="#13132a" Padding="24,16">
        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
          <Button Content="Zrušit" Command="{Binding ZrusitCommand}" Classes="secondary"/>
          <Button Content="Uložit album" Command="{Binding UlozitCommand}" Classes="primary"/>
        </StackPanel>
      </Border>

    </Grid>
  </Border>
</UserControl>
