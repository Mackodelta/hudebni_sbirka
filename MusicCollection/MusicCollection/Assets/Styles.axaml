<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Základní TextBlock -->
  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="#c8c8e8"/>
    <Setter Property="FontFamily" Value="Segoe UI, sans-serif"/>
  </Style>

  <Style Selector="TextBlock.label">
    <Setter Property="Foreground" Value="#8888aa"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <!-- TextBox -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="#1e1e38"/>
    <Setter Property="Foreground" Value="#e0e0ff"/>
    <Setter Property="BorderBrush" Value="#3a3a5c"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Padding" Value="10,8"/>
    <Setter Property="FontSize" Value="14"/>
  </Style>
  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="#6666cc"/>
  </Style>

  <!-- ComboBox -->
  <Style Selector="ComboBox">
    <Setter Property="Background" Value="#1e1e38"/>
    <Setter Property="Foreground" Value="#e0e0ff"/>
    <Setter Property="BorderBrush" Value="#3a3a5c"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Padding" Value="10,8"/>
    <Setter Property="MinHeight" Value="36"/>
  </Style>

  <!-- Buttons -->
  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Padding" Value="14,8"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15"/>
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="#5555cc"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#6666dd"/>
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="#2a2a48"/>
    <Setter Property="Foreground" Value="#c0c0e0"/>
    <Setter Property="BorderBrush" Value="#3a3a5c"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>
  <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#3a3a60"/>
  </Style>

  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="#8888cc"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#1a1a30"/>
  </Style>

  <Style Selector="Button.icon">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Padding" Value="6"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#2a2a44"/>
  </Style>

  <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#3a1a1a"/>
  </Style>

  <!-- Card -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="#1a1a30"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="14,10"/>
    <Setter Property="BorderBrush" Value="#2a2a48"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

</Styles>
